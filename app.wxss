page {
  --bg-base: #f9efe2;
  --bg-soft: #fff7ee;
  --surface-primary: rgba(255, 250, 243, 0.92);
  --surface-secondary: rgba(255, 242, 229, 0.82);
  --surface-dark: #6b2f20;
  --surface-dark-soft: #90432b;
  --surface-accent: #d95d39;
  --surface-accent-strong: #b94224;
  --surface-highlight: #efb15a;
  --surface-mint: #d88a4b;
  --text-primary: #43251a;
  --text-secondary: #815845;
  --text-tertiary: #bc957f;
  --text-inverse: #fff8f1;
  --border-soft: rgba(124, 61, 35, 0.08);
  --border-strong: rgba(124, 61, 35, 0.16);
  --shadow-soft: 0 12rpx 28rpx rgba(160, 86, 42, 0.09);
  --shadow-card: 0 18rpx 46rpx rgba(160, 86, 42, 0.13);
  --shadow-float: 0 28rpx 70rpx rgba(133, 67, 35, 0.18);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 34rpx;
  --radius-xl: 44rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 40rpx;
  --space-2xl: 56rpx;
  --space-3xl: 72rpx;
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-2xl: 52rpx;
  --duration-fast: 0.18s;
  --duration-base: 0.28s;
  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  background:
    radial-gradient(circle at top left, rgba(239, 177, 90, 0.18), transparent 36%),
    radial-gradient(circle at 85% 12%, rgba(217, 93, 57, 0.14), transparent 28%),
    linear-gradient(180deg, #fffaf4 0%, #f9efe2 48%, #f5e7d7 100%);
  color: var(--text-primary);
  min-height: 100vh;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.14) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.14) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  opacity: 0.1;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 24rpx 180rpx;
  box-sizing: border-box;
  position: relative;
}

.hero-card,
.surface-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-xl);
  box-sizing: border-box;
}

.hero-card {
  padding: 42rpx 36rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 215, 145, 0.24), transparent 26%),
    linear-gradient(145deg, #8c3b27 0%, #6b2f20 56%, #d95d39 100%);
  color: var(--text-inverse);
  box-shadow: var(--shadow-float);
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -64rpx;
  bottom: -90rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 247, 240, 0.06);
}

.hero-layout {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-side {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  align-items: stretch;
}

.hero-side-card {
  padding: 18rpx 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 247, 240, 0.1);
  border: 1rpx solid rgba(255, 247, 240, 0.08);
}

.hero-side-label {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 247, 240, 0.52);
}

.hero-side-value {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.15;
}

.hero-side-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: rgba(255, 247, 240, 0.72);
}

.surface-card {
  padding: 28rpx;
  background: var(--surface-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.section-shell {
  margin-top: 28rpx;
}

.lux-divider {
  height: 1rpx;
  margin: 18rpx 0 0;
  background: linear-gradient(90deg, transparent 0%, rgba(102, 55, 34, 0.08) 18%, rgba(102, 55, 34, 0.08) 82%, transparent 100%);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  gap: 20rpx;
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-kicker {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
}

.section-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.15;
}

.section-subtitle {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.55;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 247, 240, 0.12);
  font-size: var(--font-xs);
  line-height: 1;
  box-sizing: border-box;
}

.chip-light {
  background: rgba(217, 93, 57, 0.12);
  color: var(--surface-accent-strong);
}

.chip-mint {
  background: rgba(239, 177, 90, 0.18);
  color: #9f5e20;
}

.chip-outline {
  border: 1rpx solid var(--border-strong);
  background: rgba(255, 255, 255, 0.5);
  color: var(--text-secondary);
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 247, 240, 0.1);
  border: 1rpx solid rgba(255, 247, 240, 0.08);
  font-size: var(--font-xs);
  letter-spacing: 3rpx;
  margin-bottom: 22rpx;
}

.hero-title {
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: var(--font-base);
  line-height: 1.7;
  color: rgba(255, 247, 240, 0.78);
}

.hero-metrics {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
  flex-wrap: wrap;
}

.hero-metric {
  min-width: 150rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 247, 240, 0.08);
  border: 1rpx solid rgba(255, 247, 240, 0.06);
}

.hero-metric-value {
  display: block;
  font-size: var(--font-xl);
  font-weight: 700;
  line-height: 1;
}

.hero-metric-label {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-xs);
  color: rgba(255, 247, 240, 0.64);
}

.icon-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(217, 93, 57, 0.12);
  color: var(--surface-accent-strong);
  font-size: 28rpx;
  flex-shrink: 0;
}

.primary-btn,
.ghost-btn,
.tonal-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 82rpx;
  padding: 0 28rpx;
  min-width: 132rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  font-size: var(--font-sm);
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
  word-break: keep-all;
  text-align: center;
  flex-shrink: 0;
  transition:
    transform var(--duration-fast) var(--ease-out),
    box-shadow var(--duration-fast) var(--ease-out),
    background var(--duration-fast) var(--ease-out),
    border-color var(--duration-fast) var(--ease-out);
}

button.primary-btn,
button.ghost-btn,
button.tonal-btn {
  margin: 0;
  border: none;
  white-space: nowrap;
  word-break: keep-all;
}

button.primary-btn::after,
button.ghost-btn::after,
button.tonal-btn::after {
  border: none;
}

.primary-btn {
  color: var(--text-inverse);
  background: linear-gradient(180deg, #de6a3d 0%, #bf4425 100%);
  box-shadow: 0 12rpx 26rpx rgba(191, 68, 37, 0.22);
  letter-spacing: 1rpx;
}

.ghost-btn {
  color: var(--text-primary);
  background: rgba(255, 248, 240, 0.62);
  border: 1rpx solid rgba(124, 61, 35, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
}

.tonal-btn {
  color: #8f4d24;
  background: rgba(239, 177, 90, 0.18);
  border: 1rpx solid rgba(239, 177, 90, 0.18);
}

.primary-btn:active,
.ghost-btn:active,
.tonal-btn:active {
  transform: translateY(2rpx);
  box-shadow: none;
}

.primary-btn[disabled] {
  opacity: 0.42;
  box-shadow: none;
}

.bottom-dock {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: rgba(255, 248, 241, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 20rpx 44rpx rgba(161, 88, 44, 0.15);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  z-index: 30;
}

.dock-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.dock-copy {
  flex: 1;
  min-width: 0;
}

.dock-title {
  display: block;
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--text-primary);
}

.dock-desc {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.45;
}

.dock-action {
  min-width: 240rpx;
}

.feedback-banner {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(239, 177, 90, 0.2);
  color: #945d1d;
  font-size: var(--font-xs);
}

.empty-panel {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.fade-enter {
  animation: fadeEnter 0.45s var(--ease-out);
}

.rise-enter {
  animation: riseEnter 0.5s var(--ease-out);
}

@keyframes fadeEnter {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes riseEnter {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.985);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}


.share-panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(45, 20, 12, 0.24);
  z-index: 39;
}

.share-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 164rpx;
  z-index: 40;
  padding: 30rpx;
  border-radius: 34rpx;
  background: rgba(255, 249, 242, 0.96);
  border: 1rpx solid rgba(255, 255, 255, 0.84);
  box-shadow: 0 28rpx 70rpx rgba(125, 68, 38, 0.2);
  backdrop-filter: blur(22rpx);
  -webkit-backdrop-filter: blur(22rpx);
}

.share-panel-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.share-panel-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.share-panel-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.6;
}

.share-panel-body {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 242, 229, 0.88);
}

.share-panel-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--text-tertiary);
}

.share-panel-summary {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.6;
}

.share-panel-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.share-primary,
.share-secondary {
  width: 100%;
}
