page {
  --bg-base: #f6f1e8;
  --bg-soft: #fbf7f1;
  --surface-primary: rgba(255, 251, 245, 0.92);
  --surface-secondary: rgba(255, 248, 240, 0.72);
  --surface-dark: #163127;
  --surface-accent: #d96b4d;
  --surface-accent-strong: #bf5638;
  --surface-highlight: #f1c27d;
  --surface-mint: #7ea68a;
  --text-primary: #1f2a24;
  --text-secondary: #57655d;
  --text-tertiary: #8b948e;
  --text-inverse: #fffaf4;
  --border-soft: rgba(31, 42, 36, 0.08);
  --border-strong: rgba(31, 42, 36, 0.16);
  --shadow-soft: 0 10rpx 30rpx rgba(70, 47, 33, 0.08);
  --shadow-card: 0 18rpx 40rpx rgba(70, 47, 33, 0.12);
  --shadow-float: 0 30rpx 70rpx rgba(70, 47, 33, 0.16);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 34rpx;
  --radius-xl: 44rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 40rpx;
  --space-2xl: 56rpx;
  --space-3xl: 72rpx;
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-2xl: 52rpx;
  --duration-fast: 0.18s;
  --duration-base: 0.28s;
  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  background:
    radial-gradient(circle at top left, rgba(217, 107, 77, 0.14), transparent 38%),
    radial-gradient(circle at 85% 14%, rgba(126, 166, 138, 0.16), transparent 30%),
    linear-gradient(180deg, #fff9f2 0%, #f6f1e8 44%, #f3ede2 100%);
  color: var(--text-primary);
  min-height: 100vh;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.18) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.18) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  opacity: 0.18;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 24rpx 180rpx;
  box-sizing: border-box;
  position: relative;
}

.hero-card,
.surface-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-xl);
  box-sizing: border-box;
}

.hero-card {
  padding: 40rpx 36rpx;
  background:
    radial-gradient(circle at top right, rgba(241, 194, 125, 0.28), transparent 30%),
    linear-gradient(145deg, #214033 0%, #173126 48%, #d96b4d 140%);
  color: var(--text-inverse);
  box-shadow: var(--shadow-float);
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -60rpx;
  bottom: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.1);
}

.surface-card {
  padding: 28rpx;
  background: var(--surface-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.section-shell {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  gap: 20rpx;
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-kicker {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  letter-spacing: 4rpx;
}

.section-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.15;
}

.section-subtitle {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.5;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.16);
  font-size: var(--font-xs);
  line-height: 1;
  box-sizing: border-box;
}

.chip-light {
  background: rgba(217, 107, 77, 0.1);
  color: var(--surface-accent-strong);
}

.chip-mint {
  background: rgba(126, 166, 138, 0.12);
  color: #456150;
}

.chip-outline {
  border: 1rpx solid var(--border-strong);
  background: rgba(255, 255, 255, 0.45);
  color: var(--text-secondary);
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.12);
  font-size: var(--font-xs);
  letter-spacing: 3rpx;
  margin-bottom: 22rpx;
}

.hero-title {
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: var(--font-base);
  line-height: 1.7;
  color: rgba(255, 250, 244, 0.82);
}

.hero-metrics {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
  flex-wrap: wrap;
}

.hero-metric {
  min-width: 150rpx;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 244, 0.12);
}

.hero-metric-value {
  display: block;
  font-size: var(--font-xl);
  font-weight: 700;
  line-height: 1;
}

.hero-metric-label {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-xs);
  color: rgba(255, 250, 244, 0.72);
}

.icon-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(217, 107, 77, 0.12);
  color: var(--surface-accent-strong);
  font-size: 28rpx;
  flex-shrink: 0;
}

.primary-btn,
.ghost-btn,
.tonal-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 84rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: var(--font-sm);
  font-weight: 600;
  line-height: 1;
  transition: transform var(--duration-fast) var(--ease-out);
}

button.primary-btn,
button.ghost-btn,
button.tonal-btn {
  margin: 0;
  border: none;
}

button.primary-btn::after,
button.ghost-btn::after,
button.tonal-btn::after {
  border: none;
}

.primary-btn {
  color: var(--text-inverse);
  background: linear-gradient(135deg, #d96b4d 0%, #bf5638 100%);
  box-shadow: 0 16rpx 30rpx rgba(191, 86, 56, 0.28);
}

.ghost-btn {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.56);
  border: 1rpx solid var(--border-soft);
}

.tonal-btn {
  color: #456150;
  background: rgba(126, 166, 138, 0.14);
}

.primary-btn:active,
.ghost-btn:active,
.tonal-btn:active {
  transform: scale(0.97);
}

.primary-btn[disabled] {
  opacity: 0.45;
  box-shadow: none;
}

.bottom-dock {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  padding: 22rpx;
  border-radius: 36rpx;
  background: rgba(255, 251, 245, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 20rpx 48rpx rgba(50, 39, 29, 0.16);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  z-index: 30;
}

.dock-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.dock-copy {
  flex: 1;
  min-width: 0;
}

.dock-title {
  display: block;
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--text-primary);
}

.dock-desc {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.4;
}

.dock-action {
  min-width: 240rpx;
}

.feedback-banner {
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(241, 194, 125, 0.18);
  color: #8b5b17;
  font-size: var(--font-xs);
}

.empty-panel {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.fade-enter {
  animation: fadeEnter 0.45s var(--ease-out);
}

.rise-enter {
  animation: riseEnter 0.5s var(--ease-out);
}

@keyframes fadeEnter {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes riseEnter {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.98);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
