/* app.wxss - 全局样式 */
/* 全局主题色彩 */
page {
  --primary-color: #ff6b6b;
  --primary-gradient: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  --secondary-color: #667eea;
  --background-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --success-color: #28a745;
  --success-gradient: linear-gradient(135deg, #28a745, #34ce57);
  --text-primary: #333;
  --text-secondary: #666;
  --text-muted: #999;
  --white: #ffffff;
  --glass-bg: rgba(255, 255, 255, 0.95);
  --glass-border: rgba(255, 255, 255, 0.2);
  --shadow-light: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  --shadow-medium: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  --shadow-heavy: 0 12rpx 48rpx rgba(0, 0, 0, 0.15);
}

/* 全局背景 */
page {
  background: var(--background-gradient);
  min-height: 100vh;
  position: relative;
}

/* 全局背景装饰 */
page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 通用卡片样式 */
.glass-card {
  background: var(--glass-bg);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  box-shadow: var(--shadow-medium);
  border: 1rpx solid var(--glass-border);
  position: relative;
  z-index: 1;
}

.glass-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
  border-radius: 20rpx;
  pointer-events: none;
}

/* 通用按钮样式 */
.btn-primary {
  background: var(--primary-gradient);
  color: var(--white);
  border-radius: 25rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
}

.btn-success {
  background: var(--success-gradient);
  color: var(--white);
  border-radius: 25rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(40, 167, 69, 0.3);
  transition: all 0.3s ease;
}

.btn-success:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(40, 167, 69, 0.4);
}

/* 通用文本样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-white {
  color: var(--white);
}

/* 通用间距 */
.m-20 {
  margin: 20rpx;
}

.p-30 {
  padding: 30rpx;
}

/* 通用圆角 */
.rounded-sm {
  border-radius: 8rpx;
}

.rounded-md {
  border-radius: 12rpx;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-xl {
  border-radius: 20rpx;
}

.rounded-full {
  border-radius: 50%;
}

/* 通用阴影 */
.shadow-light {
  box-shadow: var(--shadow-light);
}

.shadow-medium {
  box-shadow: var(--shadow-medium);
}

.shadow-heavy {
  box-shadow: var(--shadow-heavy);
}

/* 动画效果 */
.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.scale-in {
  animation: scaleIn 0.2s ease-out;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}