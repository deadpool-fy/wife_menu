.action-pill,
.image-btn,
.tag-add {
  height: 72rpx;
  padding: 0 24rpx;
  font-size: var(--font-xs);
}

.form-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.field-input,
.field-textarea,
.picker-box {
  width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.44);
  border: 1rpx solid rgba(124, 61, 35, 0.06);
  box-sizing: border-box;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.field-textarea {
  min-height: 170rpx;
}

.image-panel {
  padding: 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.44);
  border: 1rpx solid rgba(124, 61, 35, 0.05);
}

.cover-preview,
.image-placeholder {
  width: 100%;
  height: 320rpx;
  border-radius: 26rpx;
}

.cover-preview {
  display: block;
}

.image-placeholder {
  background: rgba(246, 241, 232, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.image-placeholder-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.image-placeholder-desc {
  margin-top: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.image-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.picker-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.picker-value {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.editor-list,
.step-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.inline-editor,
.step-editor {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.flex-fill {
  flex: 1;
}

.amount-input {
  width: 180rpx;
}

.inline-remove {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: rgba(157, 108, 77, 0.12);
  color: var(--surface-accent-strong);
  text-align: center;
  line-height: 58rpx;
  font-size: 34rpx;
  flex-shrink: 0;
}

.step-badge {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #214033 0%, #163127 100%);
  color: var(--text-inverse);
  text-align: center;
  line-height: 58rpx;
  font-size: var(--font-sm);
  font-weight: 700;
  flex-shrink: 0;
}

.step-textarea {
  flex: 1;
  min-height: 140rpx;
}

.tag-box {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(126, 166, 138, 0.16);
  color: #456150;
  font-size: var(--font-xs);
}

.tag-remove {
  font-size: 28rpx;
  line-height: 1;
}

.tag-entry {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}
