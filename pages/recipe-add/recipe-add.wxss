.action-pill,
.image-btn,
.tag-add {
  min-width: 128rpx;
  height: 82rpx;
  padding: 0 28rpx;
  font-size: var(--font-sm);
  white-space: nowrap;
  word-break: keep-all;
}

.form-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.field-input,
.field-textarea,
.picker-box {
  width: 100%;
  min-height: 100rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.44);
  border: 1rpx solid rgba(124, 61, 35, 0.06);
  box-sizing: border-box;
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.55;
}

.field-textarea {
  min-height: 220rpx;
}

.calorie-panel {
  width: 100%;
  min-height: 116rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 247, 239, 0.98) 0%, rgba(255, 241, 228, 0.92) 100%);
  border: 1rpx solid rgba(124, 61, 35, 0.08);
  box-sizing: border-box;
}

.calorie-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calorie-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.1;
}

.calorie-status {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(214, 108, 61, 0.12);
  color: #b55a35;
  font-size: var(--font-xs);
  font-weight: 600;
}

.calorie-hint {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.6;
}

.calorie-breakdown {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
}

.calorie-item {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(124, 61, 35, 0.06);
}

.calorie-item.partial {
  background: rgba(255, 250, 244, 0.92);
}

.calorie-item-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calorie-item-name {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.calorie-item-amount {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.calorie-item-label {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.5;
}

.image-panel {
  padding: 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.44);
  border: 1rpx solid rgba(124, 61, 35, 0.05);
}

.cover-preview,
.image-placeholder {
  width: 100%;
  height: 320rpx;
  border-radius: 26rpx;
}

.cover-preview {
  display: block;
}

.image-placeholder {
  background: rgba(246, 241, 232, 0.92);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  text-align: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.image-placeholder-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.image-placeholder-desc {
  margin-top: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.image-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.picker-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.picker-value {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.editor-list,
.step-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.inline-editor,
.step-editor {
  display: flex;
  align-items: stretch;
  gap: 14rpx;
}

.editor-list .inline-editor {
  flex-wrap: wrap;
}

.flex-fill {
  flex: 1;
  min-width: 0;
}

.quantity-input {
  width: 160rpx;
  flex-shrink: 0;
}

.quantity-input {
  flex-shrink: 0;
}

.unit-quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: calc(100% - 72rpx);
}

.unit-chip {
  min-width: 86rpx;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(124, 61, 35, 0.08);
  color: var(--text-secondary);
  font-size: var(--font-sm);
  line-height: 72rpx;
  text-align: center;
  box-sizing: border-box;
}

.unit-chip.active {
  background: linear-gradient(135deg, #db673a 0%, #c24f27 100%);
  border-color: transparent;
  color: #fffaf6;
  font-weight: 700;
}

.unit-chip.more {
  background: rgba(214, 108, 61, 0.08);
  color: #b55a35;
}

.inline-remove {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: rgba(157, 108, 77, 0.12);
  color: var(--surface-accent-strong);
  text-align: center;
  line-height: 58rpx;
  font-size: 34rpx;
  flex-shrink: 0;
  margin-left: auto;
}

.step-badge {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #214033 0%, #163127 100%);
  color: var(--text-inverse);
  text-align: center;
  line-height: 58rpx;
  font-size: var(--font-sm);
  font-weight: 700;
  flex-shrink: 0;
}

.step-textarea {
  flex: 1;
  min-height: 180rpx;
}

.tag-box {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(126, 166, 138, 0.16);
  color: #456150;
  font-size: var(--font-xs);
}

.tag-remove {
  font-size: 28rpx;
  line-height: 1;
}

.tag-entry {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}
