/* 菜谱录入页面样式 */
.recipe-add-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 40rpx 0;
  color: white;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

/* 表单容器 */
.form-container {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

/* 表单分组 */
.form-section {
  margin-bottom: 60rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.required {
  color: #ff4757;
  margin-left: 5rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #667eea;
  background: white;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  transition: all 0.3s ease;
}

.form-textarea:focus {
  border-color: #667eea;
  background: white;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

/* 图片上传 */
.image-upload {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.image-upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  transition: all 0.3s ease;
}

.image-upload-btn:active {
  background: #f0f0f0;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #666;
}

/* 食材清单 */
.ingredients-list {
  margin-bottom: 20rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.ingredient-input {
  flex: 1;
  height: 70rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 15rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.ingredient-amount {
  width: 150rpx;
  height: 70rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 15rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.ingredient-remove {
  width: 50rpx;
  height: 50rpx;
  background: #ff4757;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.add-ingredient-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 70rpx;
  border: 2rpx dashed #667eea;
  border-radius: 8rpx;
  background: #f8f9ff;
  color: #667eea;
  font-size: 26rpx;
  transition: all 0.3s ease;
}

.add-ingredient-btn:active {
  background: #f0f2ff;
}

.add-icon {
  font-size: 32rpx;
  font-weight: bold;
}

/* 制作步骤 */
.steps-list {
  margin-bottom: 20rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.step-number {
  width: 50rpx;
  height: 50rpx;
  background: #667eea;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.step-textarea {
  flex: 1;
  min-height: 100rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.step-remove {
  width: 50rpx;
  height: 50rpx;
  background: #ff4757;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.add-step-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 70rpx;
  border: 2rpx dashed #667eea;
  border-radius: 8rpx;
  background: #f8f9ff;
  color: #667eea;
  font-size: 26rpx;
  transition: all 0.3s ease;
}

.add-step-btn:active {
  background: #f0f2ff;
}

/* 标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  align-items: center;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #667eea;
  color: white;
  padding: 8rpx 15rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tag-remove {
  width: 30rpx;
  height: 30rpx;
  background: rgba(255, 255, 255, 0.3);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.tag-input {
  flex: 1;
  height: 60rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  background: #fafafa;
  min-width: 200rpx;
}

/* 提交按钮 */
.submit-container {
  padding: 40rpx 0;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 5rpx 15rpx rgba(102, 126, 234, 0.3);
}

.submit-btn[disabled] {
  opacity: 0.6;
  transform: none;
}

