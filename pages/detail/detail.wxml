<!--pages/detail/detail.wxml-->
<view class="container">
  <!-- 菜品图片区域 -->
  <view class="dish-header">
    <image class="dish-image" src="{{dishDetail.image}}" mode="aspectFill"></image>
    <view class="dish-overlay">
      <view class="dish-title">{{dishDetail.name}}</view>
      <view class="dish-meta">
        <text class="category-tag">{{dishDetail.category}}</text>
        <text class="calories-tag">{{dishDetail.calories}}卡</text>
        <text class="time-tag">{{dishDetail.cookingTime}}</text>
      </view>
    </view>
  </view>

  <!-- 菜品信息区域 -->
  <view class="dish-info-section">
    <view class="section-title">菜品介绍</view>
    <view class="dish-description">{{dishDetail.description}}</view>
    
    <view class="info-grid">
      <view class="info-item">
        <view class="info-label">卡路里</view>
        <view class="info-value">{{dishDetail.calories}}卡</view>
      </view>
      <view class="info-item">
        <view class="info-label">制作时间</view>
        <view class="info-value">{{dishDetail.cookingTime}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">适合人数</view>
        <view class="info-value">{{dishDetail.servings}}人</view>
      </view>
      <view class="info-item">
        <view class="info-label">菜品类型</view>
        <view class="info-value">{{dishDetail.category}}</view>
      </view>
    </view>
  </view>

  <!-- 食材清单 -->
  <view class="ingredients-section">
    <view class="section-title">食材清单</view>
    <view class="ingredients-list">
      <view class="ingredient-item" wx:for="{{dishDetail.ingredients}}" wx:key="name">
        <view class="ingredient-name">{{item.name}}</view>
        <view class="ingredient-amount">{{item.amount}}</view>
      </view>
    </view>
  </view>

  <!-- 制作步骤 -->
  <view class="steps-section">
    <view class="section-title">制作步骤</view>
    <view class="steps-list">
      <view class="step-item" wx:for="{{dishDetail.steps}}" wx:key="step">
        <view class="step-number">{{index + 1}}</view>
        <view class="step-content">
          <view class="step-description">{{item.description}}</view>
          <image wx:if="{{item.image}}" class="step-image" src="{{item.image}}" mode="aspectFill"></image>
        </view>
      </view>
    </view>
  </view>

  <!-- 小贴士 -->
  <view class="tips-section" wx:if="{{dishDetail.tips}}">
    <view class="section-title">小贴士</view>
    <view class="tips-content">{{dishDetail.tips}}</view>
  </view>

  <!-- 底部操作区域 -->
  <view class="bottom-actions">
    <button class="btn btn-secondary" bindtap="goBack">返回</button>
    <button class="btn btn-primary" bindtap="addToMenu" wx:if="{{!isSelected}}">加入菜单</button>
    <button class="btn btn-success" bindtap="removeFromMenu" wx:else>已加入菜单</button>
    <button class="btn btn-primary" bindtap="shareDish">分享菜品</button>
  </view>
</view>
