.detail-shell {
  padding-top: 20rpx;
}

.detail-hero {
  position: relative;
  height: 620rpx;
  border-radius: 42rpx;
  overflow: hidden;
  box-shadow: var(--shadow-float);
}

.detail-cover {
  width: 100%;
  height: 100%;
}

.detail-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(16, 24, 20, 0.16) 0%, rgba(16, 24, 20, 0.82) 100%),
    radial-gradient(circle at top right, rgba(241, 194, 125, 0.28), transparent 28%);
}

.detail-copy {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx;
  color: var(--text-inverse);
}

.detail-title {
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 700;
  margin-top: 18rpx;
}

.detail-subtitle {
  margin-top: 16rpx;
  font-size: var(--font-sm);
  line-height: 1.7;
  color: rgba(255, 250, 244, 0.82);
}

.detail-chips {
  margin-top: 22rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.overview-item {
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(246, 241, 232, 0.92);
}

.overview-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.overview-value {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.result-count {
  font-size: var(--font-sm);
  color: var(--surface-accent-strong);
  background: rgba(217, 107, 77, 0.1);
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
}

.ingredient-list,
.step-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.56);
}

.ingredient-mark {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--surface-accent);
  flex-shrink: 0;
}

.ingredient-copy {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.ingredient-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
}

.ingredient-amount {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.step-index {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #214033 0%, #163127 100%);
  color: var(--text-inverse);
  text-align: center;
  line-height: 58rpx;
  font-size: var(--font-sm);
  font-weight: 700;
  flex-shrink: 0;
}

.step-body {
  flex: 1;
  padding: 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.56);
}

.step-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.7;
}

.step-image {
  width: 100%;
  height: 220rpx;
  border-radius: 22rpx;
  margin-top: 18rpx;
}

.tip-box {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(241, 194, 125, 0.2) 0%, rgba(217, 107, 77, 0.14) 100%);
}

.tip-text {
  font-size: var(--font-sm);
  color: #6f4726;
  line-height: 1.7;
}

.detail-dock {
  gap: 14rpx;
}

.detail-back,
.detail-share {
  min-width: 110rpx;
}

.detail-main {
  flex: 1;
}

.selected-btn {
  color: var(--text-inverse);
  background: linear-gradient(135deg, #7ea68a 0%, #5f8a6b 100%);
}
