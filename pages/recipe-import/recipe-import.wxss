.form-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.compact-stack {
  gap: 16rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.picker-box,
.field-input,
.field-textarea {
  width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.56);
  box-sizing: border-box;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.picker-value {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-base);
  font-weight: 600;
}

.large-textarea {
  min-height: 320rpx;
}

.submit-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.submit-btn {
  width: 100%;
}

.import-tip {
  margin-top: 18rpx;
}

.action-pill,
.mini-btn {
  height: 72rpx;
  padding: 0 24rpx;
  font-size: var(--font-xs);
}

.draft-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.draft-card {
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.56);
}

.draft-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.draft-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.draft-title {
  display: block;
  margin-top: 16rpx;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.draft-desc {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.draft-ocr {
  display: block;
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 244, 232, 0.88);
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.7;
}

.draft-meta,
.draft-preview,
.draft-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.meta-pill,
.preview-label {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(246, 241, 232, 0.92);
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.danger-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--text-inverse);
  background: linear-gradient(135deg, #d96b4d 0%, #bf5638 100%);
}
