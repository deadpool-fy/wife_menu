/* pages/index/index.wxss */
.container {
  padding: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  position: relative;
}

/* 背景装饰 */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 头部区域 */
.header {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  color: white;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.3);
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="rgba(255,255,255,0.1)"/><circle cx="75" cy="75" r="1" fill="rgba(255,255,255,0.1)"/><circle cx="50" cy="10" r="0.5" fill="rgba(255,255,255,0.1)"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
  opacity: 0.3;
  pointer-events: none;
}

.welcome-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  position: relative;
  z-index: 2;
}

.date-text {
  font-size: 24rpx;
  opacity: 0.9;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
  position: relative;
  z-index: 2;
}

/* 已选菜品区域 */
.selected-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  position: relative;
  z-index: 1;
}

.selected-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
  border-radius: 20rpx;
  pointer-events: none;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
  position: relative;
  z-index: 2;
}

.clear-btn {
  color: #ff6b6b;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border: 2rpx solid #ff6b6b;
  border-radius: 25rpx;
  background: rgba(255, 107, 107, 0.1);
  backdrop-filter: blur(5rpx);
  transition: all 0.3s ease;
  position: relative;
  z-index: 2;
}

.clear-btn:active {
  background: rgba(255, 107, 107, 0.2);
  transform: scale(0.95);
}

.selected-dishes {
  white-space: nowrap;
}

.selected-dish-item {
  display: inline-block;
  width: 120rpx;
  margin-right: 20rpx;
  position: relative;
  text-align: center;
}

.selected-dish-item .dish-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.selected-dish-item .dish-name {
  font-size: 22rpx;
  margin-top: 10rpx;
  color: #666;
  white-space: normal;
  word-break: break-all;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff6b6b;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

/* 推荐菜品区域 */
.recommend-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  position: relative;
  z-index: 1;
}

.recommend-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
  border-radius: 20rpx;
  pointer-events: none;
}

.dish-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dish-card {
  display: flex;
  flex-direction: column;
  padding: 25rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(248, 249, 250, 0.8));
  backdrop-filter: blur(5rpx);
  border-radius: 16rpx;
  position: relative;
  z-index: 2;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.dish-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.dish-content {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.dish-content .dish-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.dish-content .dish-image:active {
  transform: scale(0.95);
}

.dish-content .dish-info {
  flex: 1;
}

.dish-content .dish-info .dish-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.dish-content .dish-info .dish-category {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.dish-content .dish-info .dish-calories {
  font-size: 20rpx;
  color: #999;
}

.select-btn {
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: white;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
  min-width: 80rpx;
  text-align: center;
  align-self: flex-end;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.select-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.select-btn:active::before {
  left: 100%;
}

.select-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
}

.select-btn.selected {
  background: linear-gradient(135deg, #28a745, #34ce57);
  box-shadow: 0 4rpx 12rpx rgba(40, 167, 69, 0.3);
}

/* 底部操作区域 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  padding: 20rpx;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.1);
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  z-index: 10;
}

.send-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.send-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.send-btn:active::before {
  left: 100%;
}

.send-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.5);
}
