.weather-hero {
  overflow: hidden;
}

.weather-backdrop {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.weather-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(12rpx);
  opacity: 0.72;
}

.weather-glow-main {
  width: 280rpx;
  height: 280rpx;
  right: -40rpx;
  top: -26rpx;
}

.weather-glow-secondary {
  width: 220rpx;
  height: 220rpx;
  left: -36rpx;
  bottom: -54rpx;
}

.weather-particles {
  position: absolute;
  inset: 0;
}

.weather-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 248, 241, 0.34);
}

.weather-dot:nth-child(1) {
  top: 88rpx;
  right: 214rpx;
}

.weather-dot:nth-child(2) {
  top: 192rpx;
  right: 92rpx;
}

.weather-dot:nth-child(3) {
  bottom: 102rpx;
  left: 304rpx;
}

.weather-badge-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}

.weather-badge {
  display: inline-flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 241, 0.12);
  border: 1rpx solid rgba(255, 248, 241, 0.12);
}

.weather-badge-soft {
  background: rgba(255, 248, 241, 0.08);
}

.weather-badge-label {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 248, 241, 0.56);
}

.weather-badge-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff8f1;
}

.weather-info-card .hero-side-value {
  font-size: 42rpx;
}

.weather-info-card .hero-side-meta {
  line-height: 1.55;
}

.weather-sunny {
  background:
    radial-gradient(circle at 82% 14%, rgba(255, 214, 90, 0.62), transparent 16%),
    radial-gradient(circle at 88% 22%, rgba(255, 234, 164, 0.32), transparent 30%),
    radial-gradient(circle at 16% 88%, rgba(255, 192, 126, 0.2), transparent 28%),
    linear-gradient(145deg, #9a462d 0%, #743221 50%, #de6d40 100%);
}

.weather-sunny .weather-glow-main {
  background: rgba(255, 205, 92, 0.44);
}

.weather-sunny .weather-glow-secondary {
  background: rgba(255, 164, 116, 0.16);
}

.weather-cloudy {
  background:
    radial-gradient(circle at 72% 18%, rgba(224, 225, 223, 0.38), transparent 18%),
    radial-gradient(circle at 86% 24%, rgba(210, 214, 216, 0.26), transparent 26%),
    radial-gradient(circle at 16% 84%, rgba(173, 111, 78, 0.18), transparent 28%),
    linear-gradient(145deg, #7e4b39 0%, #684032 46%, #b96547 100%);
}

.weather-cloudy .weather-glow-main {
  background: rgba(216, 215, 208, 0.24);
}

.weather-cloudy .weather-glow-secondary {
  background: rgba(255, 184, 140, 0.12);
}

.weather-rainy {
  background:
    repeating-linear-gradient(110deg, rgba(170, 202, 223, 0.18) 0 6rpx, transparent 6rpx 26rpx),
    radial-gradient(circle at 80% 18%, rgba(140, 188, 214, 0.28), transparent 20%),
    linear-gradient(145deg, #5b4038 0%, #4a2f29 44%, #8f4d3c 100%);
}

.weather-rainy .weather-glow-main {
  background: rgba(120, 176, 210, 0.26);
}

.weather-rainy .weather-glow-secondary {
  background: rgba(255, 179, 132, 0.12);
}

.weather-snowy {
  background:
    radial-gradient(circle at 84% 16%, rgba(244, 248, 250, 0.42), transparent 18%),
    radial-gradient(circle at 72% 28%, rgba(226, 237, 245, 0.24), transparent 26%),
    radial-gradient(circle at 18% 84%, rgba(196, 225, 241, 0.2), transparent 24%),
    linear-gradient(145deg, #7a594d 0%, #62463e 48%, #c17056 100%);
}

.weather-snowy .weather-glow-main {
  background: rgba(241, 245, 248, 0.28);
}

.weather-snowy .weather-glow-secondary {
  background: rgba(201, 227, 243, 0.16);
}

.weather-foggy {
  background:
    radial-gradient(circle at 44% 18%, rgba(232, 226, 219, 0.26), transparent 24%),
    radial-gradient(circle at 70% 28%, rgba(219, 214, 207, 0.18), transparent 30%),
    linear-gradient(145deg, #815141 0%, #6d4032 48%, #bb6549 100%);
}

.weather-foggy .weather-glow-main {
  background: rgba(226, 220, 212, 0.2);
}

.weather-foggy .weather-glow-secondary {
  background: rgba(255, 193, 140, 0.12);
}

.weather-stormy {
  background:
    linear-gradient(120deg, rgba(157, 189, 216, 0.16) 0 10%, transparent 10% 22%, rgba(157, 189, 216, 0.12) 22% 28%, transparent 28% 100%),
    radial-gradient(circle at 82% 16%, rgba(166, 193, 218, 0.26), transparent 18%),
    linear-gradient(145deg, #4f352f 0%, #3d2623 46%, #864737 100%);
}

.weather-stormy .weather-glow-main {
  background: rgba(160, 188, 214, 0.2);
}

.weather-stormy .weather-glow-secondary {
  background: rgba(255, 176, 128, 0.12);
}

.weather-night {
  background:
    radial-gradient(circle at 82% 20%, rgba(237, 208, 127, 0.28), transparent 18%),
    radial-gradient(circle at 72% 14%, rgba(255, 245, 200, 0.08), transparent 28%),
    linear-gradient(145deg, #4a312e 0%, #311c1c 50%, #754032 100%);
}

.weather-night .weather-glow-main {
  background: rgba(224, 196, 126, 0.18);
}

.weather-night .weather-glow-secondary {
  background: rgba(144, 88, 61, 0.16);
}

.page-shell {
  padding-bottom: 400rpx;
}

.action-pill {
  height: 72rpx;
  padding: 0 26rpx;
  font-size: var(--font-xs);
}

.section-head-stack {
  align-items: flex-start;
  flex-direction: column;
}

.action-group {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.selected-scroll {
  width: 100%;
}

.selected-row {
  display: flex;
  gap: 18rpx;
  padding-bottom: 6rpx;
}

.selected-card {
  width: 210rpx;
  height: 250rpx;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  box-shadow: var(--shadow-soft);
}

.selected-image {
  width: 100%;
  height: 100%;
}

.selected-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 26rpx 20rpx 18rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(76, 34, 24, 0.82) 100%);
}

.selected-name {
  display: block;
  color: var(--text-inverse);
  font-size: var(--font-base);
  font-weight: 700;
  line-height: 1.25;
}

.selected-meta {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 250, 244, 0.74);
  font-size: var(--font-xs);
}

.selected-remove {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(88, 40, 27, 0.56);
  color: var(--text-inverse);
  text-align: center;
  line-height: 52rpx;
  font-size: 34rpx;
}

.feedback-banner {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(241, 194, 125, 0.18);
  color: #8b5b17;
  font-size: var(--font-xs);
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommend-card {
  border-radius: 32rpx;
  overflow: hidden;
  background: rgba(255, 250, 245, 0.68);
  border: 1rpx solid rgba(124, 61, 35, 0.06);
  box-shadow: 0 14rpx 30rpx rgba(149, 81, 41, 0.08);
}

.recommend-main {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
}

.recommend-image {
  width: 204rpx;
  height: 236rpx;
  border-radius: 26rpx;
  flex-shrink: 0;
}

.recommend-copy {
  flex: 1;
  min-width: 0;
}

.recommend-name {
  display: block;
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.recommend-desc {
  display: block;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  line-height: 1.6;
}

.recommend-meta {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.meta-block {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 245, 234, 0.92);
  border: 1rpx solid rgba(124, 61, 35, 0.04);
}

.meta-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.meta-value {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 600;
}

.recommend-action {
  padding: 0 22rpx 22rpx;
}

.action-select {
  width: 100%;
}

.action-select.selected {
  background: linear-gradient(180deg, #de6a3d 0%, #b94224 100%);
  box-shadow: 0 12rpx 26rpx rgba(185, 66, 36, 0.22);
}

.empty-panel {
  padding: 40rpx 20rpx 20rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.share-panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(45, 20, 12, 0.24);
  z-index: 39;
}

.share-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 164rpx;
  z-index: 40;
  padding: 30rpx;
  border-radius: 34rpx;
  background: rgba(255, 249, 242, 0.96);
  border: 1rpx solid rgba(255, 255, 255, 0.84);
  box-shadow: 0 28rpx 70rpx rgba(125, 68, 38, 0.2);
  backdrop-filter: blur(22rpx);
  -webkit-backdrop-filter: blur(22rpx);
}

.share-panel-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.share-panel-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.share-panel-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.6;
}

.share-panel-body {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 242, 229, 0.88);
}

.share-panel-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--text-tertiary);
}

.share-panel-summary {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.6;
}

.share-panel-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.share-primary,
.share-secondary {
  width: 100%;
}

.bottom-dock {
  bottom: 164rpx;
}
