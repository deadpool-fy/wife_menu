.action-pill {
  height: 72rpx;
  padding: 0 26rpx;
  font-size: var(--font-xs);
}

.section-head-stack {
  align-items: flex-start;
  flex-direction: column;
}

.action-group {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.selected-scroll {
  width: 100%;
}

.selected-row {
  display: flex;
  gap: 18rpx;
  padding-bottom: 6rpx;
}

.selected-card {
  width: 210rpx;
  height: 250rpx;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  box-shadow: var(--shadow-soft);
}

.selected-image {
  width: 100%;
  height: 100%;
}

.selected-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 26rpx 20rpx 18rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(76, 34, 24, 0.82) 100%);
}

.selected-name {
  display: block;
  color: var(--text-inverse);
  font-size: var(--font-base);
  font-weight: 700;
  line-height: 1.25;
}

.selected-meta {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 250, 244, 0.74);
  font-size: var(--font-xs);
}

.selected-remove {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(88, 40, 27, 0.56);
  color: var(--text-inverse);
  text-align: center;
  line-height: 52rpx;
  font-size: 34rpx;
}

.feedback-banner {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(241, 194, 125, 0.18);
  color: #8b5b17;
  font-size: var(--font-xs);
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommend-card {
  border-radius: 32rpx;
  overflow: hidden;
  background: rgba(255, 250, 245, 0.68);
  border: 1rpx solid rgba(124, 61, 35, 0.06);
  box-shadow: 0 14rpx 30rpx rgba(149, 81, 41, 0.08);
}

.recommend-main {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
}

.recommend-image {
  width: 204rpx;
  height: 236rpx;
  border-radius: 26rpx;
  flex-shrink: 0;
}

.recommend-copy {
  flex: 1;
  min-width: 0;
}

.recommend-name {
  display: block;
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.recommend-desc {
  display: block;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  line-height: 1.6;
}

.recommend-meta {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.meta-block {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 245, 234, 0.92);
  border: 1rpx solid rgba(124, 61, 35, 0.04);
}

.meta-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.meta-value {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 600;
}

.recommend-action {
  padding: 0 22rpx 22rpx;
}

.action-select {
  width: 100%;
}

.action-select.selected {
  background: linear-gradient(180deg, #de6a3d 0%, #b94224 100%);
  box-shadow: 0 12rpx 26rpx rgba(185, 66, 36, 0.22);
}

.empty-panel {
  padding: 40rpx 20rpx 20rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}
