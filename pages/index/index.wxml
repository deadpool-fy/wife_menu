<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部欢迎区域 -->
  <view class="header">
    <view class="header-content">
      <view class="welcome-section">
        <view class="welcome-icon">🍽️</view>
        <view class="welcome-text">今天想吃什么？</view>
        <view class="date-text">{{currentDate}}</view>
      </view>
      <view class="weather-info">
        <view class="weather-icon">☀️</view>
        <view class="weather-text">适合下厨的好天气</view>
      </view>
    </view>
    <view class="header-decoration">
      <view class="decoration-circle circle-1"></view>
      <view class="decoration-circle circle-2"></view>
      <view class="decoration-circle circle-3"></view>
    </view>
  </view>

  <!-- 已选菜品区域 -->
  <view class="selected-section glass-card fade-in" wx:if="{{selectedDishes.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <view class="title-icon">✅</view>
        <text>已选择的菜品</text>
        <view class="count-badge">{{selectedDishes.length}}</view>
      </view>
      <view class="clear-btn" bindtap="clearSelected">
        <view class="clear-icon">🗑️</view>
        <text>清空</text>
      </view>
    </view>
    <scroll-view class="selected-dishes" scroll-x="true" show-scrollbar="{{false}}">
      <view class="selected-dish-item scale-in" 
            wx:for="{{selectedDishes}}" 
            wx:key="id"
            style="animation-delay: {{index * 0.1}}s">
        <view class="dish-card-inner">
          <image class="dish-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="dish-overlay">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-category">{{item.category}}</view>
          </view>
          <view class="remove-btn" bindtap="removeDish" data-id="{{item.id}}">
            <text>×</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 推荐菜品区域 -->
  <view class="recommend-section glass-card fade-in">
    <view class="section-header">
      <view class="section-title">
        <view class="title-icon">🌟</view>
        <text>今日推荐</text>
        <view class="recommend-tag">精选</view>
      </view>
      <view class="header-actions">
        <view class="admin-btn" bindtap="goToAdmin">
          <view class="btn-icon">⚙️</view>
          <text>管理</text>
        </view>
        <view class="refresh-btn" bindtap="refreshRecommend">
          <view class="refresh-icon">🔄</view>
          <text>换一批</text>
        </view>
      </view>
    </view>
    <view class="dish-grid">
      <view class="dish-card hover-lift scale-in" 
            wx:for="{{recommendDishes}}" 
            wx:key="id"
            style="animation-delay: {{index * 0.1}}s">
        <view class="dish-content" bindtap="goToDetail" data-dish="{{item}}">
          <view class="dish-image-container">
            <image class="dish-image" src="{{item.image}}" mode="aspectFill"></image>
            <view class="dish-badge" wx:if="{{item.isNew}}">新品</view>
            <view class="dish-favorite" wx:if="{{item.isFavorite}}">❤️</view>
          </view>
          <view class="dish-info">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-meta">
              <view class="dish-category">{{item.category}}</view>
              <view class="dish-difficulty">{{item.difficulty}}</view>
            </view>
            <view class="dish-stats">
              <view class="stat-item">
                <text class="stat-icon">🔥</text>
                <text class="stat-text">{{item.calories}}卡</text>
              </view>
              <view class="stat-item">
                <text class="stat-icon">⏱️</text>
                <text class="stat-text">{{item.cookingTime}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="dish-actions">
          <view class="select-btn {{item.selected ? 'selected' : ''}}" 
                bindtap="selectDish" 
                data-dish="{{item}}">
            <view class="btn-icon">{{item.selected ? '✓' : '+'}}</view>
            <text>{{item.selected ? '已选' : '选择'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作区域 -->
  <view class="bottom-actions slide-up" wx:if="{{selectedDishes.length > 0}}">
    <view class="actions-content">
      <view class="selected-summary">
        <view class="summary-icon">🍽️</view>
        <view class="summary-text">
          <text class="summary-count">{{selectedDishes.length}}道菜</text>
          <text class="summary-desc">已准备就绪</text>
        </view>
      </view>
      <button class="btn btn-primary btn-lg send-btn" bindtap="sendToWeChat">
        <view class="btn-content">
          <view class="btn-icon">💌</view>
          <text>发送给老公</text>
        </view>
      </button>
    </view>
    <view class="actions-decoration">
      <view class="decoration-dot"></view>
      <view class="decoration-dot"></view>
      <view class="decoration-dot"></view>
    </view>
  </view>
</view>
