<view class="page-shell">
  <view class="hero-card rise-enter">
    <view class="hero-layout">
      <view class="hero-copy">
        <view class="hero-eyebrow">
          <text>DINNER STUDIO</text>
          <text>{{currentDate}}</text>
        </view>
        <view class="hero-title">把今天这顿饭，选得像精心策划过一样。</view>
        <view class="hero-subtitle">{{heroTip}}</view>
        <view class="hero-metrics">
          <view class="hero-metric">
            <text class="hero-metric-value">{{recommendDishes.length}}</text>
            <text class="hero-metric-label">今日推荐</text>
          </view>
          <view class="hero-metric">
            <text class="hero-metric-value">{{selectedDishes.length}}</text>
            <text class="hero-metric-label">已选菜单</text>
          </view>
        </view>
      </view>
      <view class="hero-side">
        <view class="hero-side-card">
          <text class="hero-side-label">CURATOR NOTE</text>
          <text class="hero-side-value">NOW</text>
          <text class="hero-side-meta">{{todayMood}}</text>
        </view>
        <view class="hero-side-card">
          <text class="hero-side-label">SERVICE</text>
          <text class="hero-side-value">01</text>
          <text class="hero-side-meta">从推荐、搭配到发送，一屏完成今晚菜单。</text>
        </view>
      </view>
    </view>
  </view>

  <view class="surface-card section-shell fade-enter" wx:if="{{selectedDishes.length > 0}}">
    <view class="section-head">
      <view class="section-title-wrap">
        <text class="section-kicker">CURATED MENU</text>
        <text class="section-title">已选菜单</text>
        <text class="section-subtitle">继续补齐几道菜，就能直接发给家人确认今晚安排。</text>
      </view>
      <view class="ghost-btn action-pill" bindtap="clearSelected">清空</view>
    </view>

    <scroll-view class="selected-scroll" scroll-x="true" show-scrollbar="{{false}}">
      <view class="selected-row">
        <view class="selected-card" wx:for="{{selectedDishes}}" wx:key="id">
          <image class="selected-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="selected-overlay">
            <text class="selected-name">{{item.name}}</text>
            <text class="selected-meta">{{item.category}}</text>
          </view>
          <view class="selected-remove" bindtap="removeDish" data-id="{{item.id}}">×</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="surface-card section-shell fade-enter">
    <view class="section-head section-head-stack">
      <view class="section-title-wrap">
        <text class="section-kicker">EDITOR PICKS</text>
        <text class="section-title">今日推荐</text>
        <text class="section-subtitle">挑一份更有卖相的家常菜单，兼顾速度、热量和下厨难度。</text>
      </view>
      <view class="action-group">
        <view class="tonal-btn action-pill" bindtap="goToAdmin">后台管理</view>
        <view class="ghost-btn action-pill" bindtap="refreshRecommend">换一批</view>
      </view>
    </view>
    <view class="lux-divider"></view>

    <view class="feedback-banner" wx:if="{{error}}">
      <text>{{error}}</text>
    </view>

    <view class="recommend-list" wx:if="{{recommendDishes.length > 0}}">
      <view class="recommend-card" wx:for="{{recommendDishes}}" wx:key="id">
        <view class="recommend-main" bindtap="goToDetail" data-id="{{item.id}}">
          <image class="recommend-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="recommend-copy">
            <view class="chip-row">
              <text class="chip chip-light">{{item.category}}</text>
              <text class="chip chip-mint">{{item.difficulty}}</text>
              <text class="chip chip-outline" wx:if="{{item.isNew}}">新推荐</text>
            </view>
            <text class="recommend-name">{{item.name}}</text>
            <text class="recommend-desc">适合 {{item.servings}} 人分享，制作时间约 {{item.cookingTime}}，热量 {{item.calories}} kcal。</text>
            <view class="recommend-meta">
              <view class="meta-block">
                <text class="meta-label">烹饪时间</text>
                <text class="meta-value">{{item.cookingTime}}</text>
              </view>
              <view class="meta-block">
                <text class="meta-label">适合人数</text>
                <text class="meta-value">{{item.servings}} 人</text>
              </view>
              <view class="meta-block">
                <text class="meta-label">热量</text>
                <text class="meta-value">{{item.calories}} kcal</text>
              </view>
            </view>
          </view>
        </view>
        <view class="recommend-action">
          <view class="primary-btn action-select {{item.selected ? 'selected' : ''}}" bindtap="selectDish" data-dish="{{item}}">
            <text>{{item.selected ? '已加入菜单' : '加入菜单'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-panel" wx:else>
      <text class="empty-title">推荐菜单还在整理中</text>
      <text class="empty-desc">稍后再试，或者先去分类页自己搭一套更合口味的组合。</text>
    </view>
  </view>

  <view class="bottom-dock rise-enter" wx:if="{{selectedDishes.length > 0 && !sharePanelVisible}}">
    <view class="dock-content">
      <view class="icon-badge">荐</view>
      <view class="dock-copy">
        <text class="dock-title">已选 {{selectedDishes.length}} 道菜</text>
        <text class="dock-desc">现在就可以整理成菜单并发送，也可以继续从推荐里补充。</text>
      </view>
      <button class="primary-btn dock-action" bindtap="sendToWeChat">发送菜单</button>
    </view>
  </view>

  <view class="share-panel-mask" wx:if="{{sharePanelVisible}}" bindtap="closeSharePanel"></view>
  <view class="share-panel rise-enter" wx:if="{{sharePanelVisible}}">
    <view class="share-panel-head">
      <text class="share-panel-title">分享给朋友</text>
      <text class="share-panel-desc">这里会直接拉起微信原生分享面板，不再只是复制到剪贴板。</text>
    </view>
    <view class="share-panel-body">
      <text class="share-panel-label">本次菜单</text>
      <text class="share-panel-summary">{{shareSummary}}</text>
    </view>
    <view class="share-panel-actions">
      <button class="ghost-btn share-secondary" bindtap="closeSharePanel">先不分享</button>
      <button class="primary-btn share-primary" open-type="share">立即分享</button>
    </view>
  </view>
</view>
