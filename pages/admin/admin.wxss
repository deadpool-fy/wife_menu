.action-pill {
  height: 72rpx;
  padding: 0 24rpx;
  font-size: var(--font-xs);
}

.console-grid {
  display: grid;
  gap: 18rpx;
}

.two-col {
  grid-template-columns: 1fr 1fr;
}

.console-card {
  padding: 28rpx;
  border-radius: 32rpx;
  color: var(--text-inverse);
  min-height: 220rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: var(--shadow-soft);
  position: relative;
  overflow: hidden;
}

.console-card::after {
  content: "";
  position: absolute;
  right: -30rpx;
  bottom: -40rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.accent-card {
  background: linear-gradient(160deg, #24362c 0%, #1a2a22 100%);
}

.mint-card {
  background: linear-gradient(160deg, #657a6f 0%, #53675d 100%);
}

.neutral-card {
  background: linear-gradient(160deg, #6c5948 0%, #564537 100%);
}

.console-tag {
  display: inline-block;
  font-size: 20rpx;
  opacity: 0.72;
  letter-spacing: 3rpx;
}

.console-title {
  display: block;
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.2;
}

.console-desc {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-sm);
  line-height: 1.6;
  color: rgba(255, 250, 244, 0.8);
}

.danger-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.danger-item {
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(127, 83, 56, 0.14);
  background: rgba(157, 108, 77, 0.07);
}

.danger-title {
  display: block;
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--surface-accent-strong);
}

.danger-desc {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: #775f4d;
  line-height: 1.6;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.log-item {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.46);
  border: 1rpx solid rgba(124, 61, 35, 0.05);
}

.log-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.log-message {
  font-size: var(--font-sm);
  line-height: 1.6;
}

.log-message.success {
  color: #456150;
}

.log-message.info {
  color: var(--text-primary);
}

.log-message.error {
  color: var(--surface-accent-strong);
}
