/* pages/rating/rating.wxss */
.container {
  padding: 0;
  background: var(--background-primary);
  min-height: 100vh;
  padding-bottom: 120rpx;
  position: relative;
}

/* 头部区域 */
.header {
  background: var(--primary-gradient);
  padding: var(--space-3xl) var(--space-xl) var(--space-xl);
  position: relative;
  z-index: 1;
  box-shadow: var(--shadow-lg);
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 70% 80%, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
  pointer-events: none;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 2;
}

.welcome-section {
  flex: 1;
}

.welcome-icon {
  font-size: var(--text-4xl);
  margin-bottom: var(--space-sm);
  animation: bounceIn var(--duration-slow) var(--ease-bounce);
}

.title {
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--text-white);
  margin-bottom: var(--space-xs);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: var(--text-base);
  color: var(--text-white);
  opacity: 0.9;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.rating-progress {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-xl);
  padding: var(--space-md);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  min-width: 200rpx;
}

.progress-text {
  font-size: var(--text-sm);
  color: var(--text-white);
  margin-bottom: var(--space-sm);
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: var(--space-sm);
}

.progress-fill {
  height: 100%;
  background: var(--success-gradient);
  border-radius: var(--radius-full);
  transition: width var(--duration-normal) var(--ease-out);
}

.progress-count {
  font-size: var(--text-sm);
  color: var(--text-white);
  font-weight: 600;
}

.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.decoration-star {
  position: absolute;
  font-size: var(--text-2xl);
  animation: float 6s ease-in-out infinite;
  opacity: 0.6;
}

.star-1 {
  top: 20rpx;
  right: 40rpx;
  animation-delay: 0s;
}

.star-2 {
  top: 60rpx;
  left: 20rpx;
  animation-delay: 2s;
}

.star-3 {
  bottom: 20rpx;
  right: 20rpx;
  animation-delay: 4s;
}

/* 菜品列表 */
.dishes-list {
  padding: var(--space-lg);
}

.dish-item {
  margin-bottom: var(--space-lg);
  position: relative;
  z-index: 1;
}

.dish-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-xl);
  padding: var(--space-lg);
  background: var(--glass-bg-light);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border-light);
}

.dish-image-container {
  position: relative;
  margin-right: var(--space-lg);
}

.dish-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  transition: transform var(--duration-normal) var(--ease-out);
}

.dish-image:hover {
  transform: scale(1.05);
}

.dish-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: var(--success-gradient);
  color: var(--text-white);
  font-size: var(--text-xs);
  font-weight: 600;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
}

.dish-info {
  flex: 1;
}

.dish-name {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  line-height: 1.3;
}

.dish-meta {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.dish-category, .dish-difficulty {
  font-size: var(--text-xs);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.dish-category {
  background: rgba(255, 107, 107, 0.1);
  color: var(--primary-color);
}

.dish-difficulty {
  background: rgba(40, 167, 69, 0.1);
  color: var(--success-color);
}

.dish-stats {
  display: flex;
  gap: var(--space-md);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.stat-icon {
  font-size: var(--text-sm);
}

.stat-text {
  font-size: var(--text-xs);
  color: var(--text-secondary);
}

/* 评分区域 */
.rating-section {
  margin-bottom: var(--space-xl);
  padding: var(--space-lg);
  background: var(--glass-bg-light);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border-light);
}

.rating-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.rating-label {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--text-primary);
}

.label-icon {
  font-size: var(--text-base);
}

.rating-status {
  font-size: var(--text-sm);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-full);
  font-weight: 500;
}

.rating-status.completed {
  background: rgba(40, 167, 69, 0.1);
  color: var(--success-color);
}

.rating-status.pending {
  background: rgba(255, 193, 7, 0.1);
  color: var(--warning-color);
}

.stars {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
  justify-content: center;
}

.star {
  font-size: var(--text-3xl);
  color: var(--text-light);
  transition: all var(--duration-normal) var(--ease-out);
  cursor: pointer;
}

.star:hover {
  transform: scale(1.2);
}

.star.active {
  color: var(--warning-color);
  transform: scale(1.1);
  filter: drop-shadow(0 2rpx 4rpx rgba(255, 193, 7, 0.3));
}

.rating-text {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  text-align: center;
  font-weight: 500;
}

/* 评价内容 */
.comment-section {
  margin-bottom: var(--space-lg);
  padding: var(--space-lg);
  background: var(--glass-bg-light);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border-light);
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.comment-label {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--text-primary);
}

.comment-count {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  background: rgba(102, 126, 234, 0.1);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-full);
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  padding: var(--space-lg);
  border: 2rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  font-size: var(--text-base);
  line-height: 1.5;
  background: var(--glass-bg);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  box-sizing: border-box;
  transition: all var(--duration-normal) var(--ease-out);
}

.comment-input:focus {
  border-color: var(--primary-color);
  background: var(--bg-white);
  box-shadow: var(--shadow-md);
}

/* 底部操作区域 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: var(--space-lg);
  box-shadow: var(--shadow-xl);
  border-top: 1rpx solid var(--glass-border);
  z-index: 10;
}

.actions-content {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  margin-bottom: var(--space-sm);
}

.rating-summary {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  flex: 1;
}

.summary-icon {
  font-size: var(--text-2xl);
  animation: pulse 2s var(--ease-in-out) infinite;
}

.summary-text {
  display: flex;
  flex-direction: column;
}

.summary-count {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.summary-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.action-buttons {
  display: flex;
  gap: var(--space-md);
}

.bottom-actions .btn {
  height: 80rpx;
  font-size: var(--text-base);
  border-radius: var(--radius-2xl);
}

.bottom-actions .btn[disabled] {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: var(--shadow-xs) !important;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  height: 100%;
}

.btn-icon {
  font-size: var(--text-base);
}

.actions-decoration {
  display: flex;
  justify-content: center;
  gap: var(--space-sm);
}

.decoration-dot {
  width: 8rpx;
  height: 8rpx;
  background: var(--primary-color);
  border-radius: var(--radius-full);
  opacity: 0.6;
  animation: pulse 2s var(--ease-in-out) infinite;
}

.decoration-dot:nth-child(2) {
  animation-delay: 0.5s;
}

.decoration-dot:nth-child(3) {
  animation-delay: 1s;
}
