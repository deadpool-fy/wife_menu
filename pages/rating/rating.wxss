.progress-card {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 250, 244, 0.12);
}

.progress-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: var(--font-sm);
  color: rgba(255, 250, 244, 0.74);
}

.progress-value {
  font-size: var(--font-lg);
  font-weight: 700;
}

.progress-track {
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.16);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f1c27d 0%, #fff1cc 100%);
}

.rating-summary {
  padding-top: 26rpx;
}

.compact-head {
  margin-bottom: 18rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-item {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 245, 234, 0.88);
}

.summary-value {
  display: block;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--surface-accent-strong);
}

.summary-label {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.5;
}

.rating-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rating-card {
  padding: 24rpx;
}

.rating-header-row {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.rating-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.rating-copy {
  flex: 1;
  min-width: 0;
}

.rating-name {
  display: block;
  margin-top: 16rpx;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.rating-desc {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.status-chip {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: var(--font-xs);
  color: #9a6c22;
  background: rgba(241, 194, 125, 0.2);
}

.status-chip.done {
  color: #456150;
  background: rgba(126, 166, 138, 0.18);
}

.editor-block {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.5);
}

.editor-title {
  display: block;
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--text-primary);
}

.strong-helper {
  margin-top: 10rpx;
}

.star-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.star {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: rgba(241, 194, 125, 0.14);
  color: #c6bdb0;
  text-align: center;
  line-height: 64rpx;
  font-size: 34rpx;
}

.star.active {
  background: rgba(241, 194, 125, 0.24);
  color: #d68b12;
}

.editor-helper {
  display: block;
  margin-top: 14rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.6;
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.comment-count {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.comment-box {
  width: 100%;
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(246, 241, 232, 0.92);
  box-sizing: border-box;
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.6;
}

.rating-dock-panel {
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
}

.rating-dock-copy {
  min-width: 0;
}

.rating-dock-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  width: 100%;
}

.rating-skip,
.rating-submit {
  width: 100%;
  min-width: 0;
}
