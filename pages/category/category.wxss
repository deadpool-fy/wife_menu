/* pages/category/category.wxss */
.container {
  padding: 0;
  background: var(--background-primary);
  min-height: 100vh;
  padding-bottom: 120rpx;
  position: relative;
}

/* 分类标签区域 */
.category-tabs {
  margin: var(--space-lg);
  padding: var(--space-xl);
  position: relative;
  z-index: 1;
}

.tabs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.tabs-title {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.title-icon {
  font-size: var(--text-lg);
}

.tabs-count {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  background: rgba(102, 126, 234, 0.1);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-full);
}

.tabs-scroll {
  white-space: nowrap;
  padding: var(--space-sm) 0;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  margin-right: var(--space-md);
  border-radius: var(--radius-xl);
  font-size: var(--text-sm);
  color: var(--text-secondary);
  background: var(--glass-bg-light);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  transition: all var(--duration-normal) var(--ease-out);
  border: 1rpx solid var(--glass-border-light);
  min-width: 120rpx;
  text-align: center;
}

.tab-item.active {
  background: var(--primary-gradient);
  color: var(--text-white);
  box-shadow: var(--shadow-md);
  transform: translateY(-2rpx);
}

.tab-icon {
  font-size: var(--text-lg);
  margin-bottom: var(--space-xs);
}

/* 菜品网格区域 */
.dishes-grid {
  padding: var(--space-lg);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-lg);
}

.dish-card {
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  border: 1rpx solid var(--glass-border);
  position: relative;
  z-index: 1;
  transition: all var(--duration-normal) var(--ease-out);
}

.dish-card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-md);
}

.dish-image-container {
  position: relative;
  height: 200rpx;
  overflow: hidden;
}

.dish-image {
  width: 100%;
  height: 100%;
  transition: transform var(--duration-normal) var(--ease-out);
}

.dish-card:active .dish-image {
  transform: scale(1.05);
}

.dish-badge {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  background: var(--success-gradient);
  color: var(--text-white);
  font-size: var(--text-xs);
  font-weight: 600;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
}

.dish-favorite {
  position: absolute;
  top: var(--space-sm);
  left: var(--space-sm);
  font-size: var(--text-lg);
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.dish-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: var(--space-md);
  color: var(--text-white);
}

.overlay-content .dish-name {
  font-size: var(--text-base);
  font-weight: 600;
  margin-bottom: var(--space-xs);
  line-height: 1.2;
}

.overlay-content .dish-category {
  font-size: var(--text-xs);
  opacity: 0.9;
}

.dish-info {
  padding: var(--space-lg);
}

.dish-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.meta-icon {
  font-size: var(--text-sm);
}

.meta-text {
  font-size: var(--text-xs);
  color: var(--text-secondary);
}

.dish-tags {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.tag {
  font-size: var(--text-xs);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.difficulty-tag {
  background: rgba(40, 167, 69, 0.1);
  color: var(--success-color);
}

.category-tag {
  background: rgba(255, 107, 107, 0.1);
  color: var(--primary-color);
}

.dish-actions {
  padding: 0 var(--space-lg) var(--space-lg);
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  width: 100%;
  padding: var(--space-md);
  text-align: center;
  border-radius: var(--radius-lg);
  font-size: var(--text-sm);
  font-weight: 600;
  background: var(--primary-gradient);
  color: var(--text-white);
  box-shadow: var(--shadow-md);
  transition: all var(--duration-normal) var(--ease-out);
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left var(--duration-slow) var(--ease-out);
}

.action-btn:active::before {
  left: 100%;
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-sm);
}

.action-btn.selected {
  background: var(--success-gradient);
  box-shadow: var(--shadow-md);
}

.btn-icon {
  font-size: var(--text-sm);
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--space-3xl) var(--space-xl);
  text-align: center;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.6;
  animation: pulse 2s var(--ease-in-out) infinite;
}

.empty-text {
  font-size: var(--text-lg);
  color: var(--text-primary);
  font-weight: 600;
}

.empty-desc {
  font-size: var(--text-base);
  color: var(--text-secondary);
}

.empty-actions {
  margin-top: var(--space-md);
}

.empty-btn {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-md) var(--space-lg);
  background: var(--secondary-gradient);
  color: var(--text-white);
  border-radius: var(--radius-xl);
  font-size: var(--text-sm);
  font-weight: 600;
  box-shadow: var(--shadow-md);
  transition: all var(--duration-normal) var(--ease-out);
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-sm);
}

/* 底部操作区域 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: var(--space-lg);
  box-shadow: var(--shadow-xl);
  border-top: 1rpx solid var(--glass-border);
  z-index: 10;
}

.actions-content {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  margin-bottom: var(--space-sm);
}

.selected-info {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  flex: 1;
}

.info-icon {
  font-size: var(--text-2xl);
  animation: pulse 2s var(--ease-in-out) infinite;
}

.info-text {
  display: flex;
  flex-direction: column;
}

.info-count {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.info-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  height: 100%;
}

.btn-icon {
  font-size: var(--text-lg);
}

.actions-decoration {
  display: flex;
  justify-content: center;
  gap: var(--space-sm);
}

.decoration-dot {
  width: 8rpx;
  height: 8rpx;
  background: var(--primary-color);
  border-radius: var(--radius-full);
  opacity: 0.6;
  animation: pulse 2s var(--ease-in-out) infinite;
}

.decoration-dot:nth-child(2) {
  animation-delay: 0.5s;
}

.decoration-dot:nth-child(3) {
  animation-delay: 1s;
}
