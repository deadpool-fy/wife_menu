.page-shell {
  padding-bottom: 400rpx;
}

.result-count {
  font-size: var(--font-sm);
  color: var(--surface-accent-strong);
  background: rgba(217, 107, 77, 0.1);
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
}

.category-scroll {
  width: 100%;
}

.category-row {
  display: flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.category-chip {
  min-width: 146rpx;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.56);
  border: 1rpx solid var(--border-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.category-chip.active {
  background: linear-gradient(135deg, #214033 0%, #163127 100%);
  color: var(--text-inverse);
  box-shadow: var(--shadow-soft);
}

.category-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  background: rgba(217, 107, 77, 0.12);
  color: var(--surface-accent-strong);
}

.category-chip.active .category-icon {
  background: rgba(255, 250, 244, 0.12);
  color: var(--text-inverse);
}

.category-name {
  font-size: var(--font-sm);
  font-weight: 600;
}

.dish-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding-bottom: 24rpx;
}

.dish-card {
  padding: 16rpx;
}

.dish-visual {
  position: relative;
  height: 330rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.dish-image {
  width: 100%;
  height: 100%;
}

.dish-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(16, 24, 20, 0.08) 0%, rgba(16, 24, 20, 0.82) 100%);
}

.dish-topline {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  right: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dish-copy {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
}

.dish-name {
  display: block;
  color: var(--text-inverse);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.dish-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 250, 244, 0.8);
  font-size: var(--font-xs);
  line-height: 1.5;
}

.dish-footer {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 16rpx;
}

.dish-stat {
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(246, 241, 232, 0.92);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.dish-actions {
  margin-top: 16rpx;
}

.select-btn {
  width: 100%;
  height: 76rpx;
  font-size: var(--font-xs);
}

.select-btn.selected {
  background: linear-gradient(135deg, #7ea68a 0%, #5f8a6b 100%);
  box-shadow: 0 16rpx 30rpx rgba(95, 138, 107, 0.22);
}

.empty-btn {
  margin-top: 22rpx;
}

.bottom-dock {
  bottom: 164rpx;
}
