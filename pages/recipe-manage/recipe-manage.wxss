.action-row {
  display: flex;
  gap: 14rpx;
}

.action-main {
  flex: 1;
}

.filter-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.picker-box,
.field-input {
  width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.44);
  border: 1rpx solid rgba(124, 61, 35, 0.06);
  box-sizing: border-box;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.field-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.picker-value {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-base);
  font-weight: 600;
}

.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recipe-card {
  padding: 20rpx;
  border: 1rpx solid rgba(124, 61, 35, 0.05);
  box-shadow: 0 12rpx 28rpx rgba(36, 28, 21, 0.05);
}

.recipe-main {
  display: flex;
  gap: 18rpx;
}

.recipe-image {
  width: 180rpx;
  height: 204rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.recipe-copy {
  flex: 1;
  min-width: 0;
}

.recipe-title {
  display: block;
  margin-top: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.recipe-desc {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.recipe-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meta-pill {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(244, 239, 230, 0.9);
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.tag-box {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(126, 166, 138, 0.16);
  color: #456150;
  font-size: var(--font-xs);
}

.recipe-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-btn {
  flex: 1;
  height: 72rpx;
  padding: 0 10rpx;
  font-size: var(--font-xs);
}

.danger-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--text-inverse);
  background: linear-gradient(180deg, #8d6044 0%, #734a34 100%);
}
