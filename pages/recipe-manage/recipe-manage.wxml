<view class="page-shell">
  <view class="hero-card rise-enter">
    <view class="hero-layout">
      <view class="hero-copy">
        <view class="hero-eyebrow">
          <text>CONTENT LIBRARY</text>
          <text>菜谱管理</text>
        </view>
        <view class="hero-title">把菜谱库管理成资产，而不是一堆散落数据。</view>
        <view class="hero-subtitle">这里统一查看统计、筛选内容、预览详情和删除无效数据，让后台维护真正有秩序。</view>
        <view class="hero-metrics">
          <view class="hero-metric">
            <text class="hero-metric-value">{{stats.totalRecipes || 0}}</text>
            <text class="hero-metric-label">总菜谱数</text>
          </view>
          <view class="hero-metric">
            <text class="hero-metric-value">{{stats.totalCategories || 0}}</text>
            <text class="hero-metric-label">分类数</text>
          </view>
        </view>
      </view>
      <view class="hero-side">
        <view class="hero-side-card">
          <text class="hero-side-label">RECENT</text>
          <text class="hero-side-value">{{stats.recentRecipes.length || 0}}</text>
          <text class="hero-side-meta">最近新增内容，适合优先检查质量和完整度。</text>
        </view>
      </view>
    </view>
  </view>

  <view class="surface-card section-shell fade-enter">
    <view class="section-head">
      <view class="section-title-wrap">
        <text class="section-kicker">ACTIONS</text>
        <text class="section-title">常用操作</text>
      </view>
    </view>
    <view class="action-row">
      <button class="primary-btn action-main" bindtap="addRecipe">新增菜谱</button>
      <button class="ghost-btn action-main" bindtap="refreshData">刷新列表</button>
    </view>
  </view>

  <view class="surface-card section-shell fade-enter">
    <view class="section-head">
      <view class="section-title-wrap">
        <text class="section-kicker">FILTERS</text>
        <text class="section-title">筛选与搜索</text>
        <text class="section-subtitle">快速缩小范围，避免内容一多就完全失控。</text>
      </view>
    </view>
    <view class="lux-divider"></view>
    <view class="filter-stack">
      <picker range="{{categories}}" range-key="name" value="{{filterCategoryIndex}}" bindchange="onCategoryFilterChange">
        <view class="picker-box">
          <text class="field-label">分类</text>
          <text class="picker-value">{{filterCategoryIndex >= 0 ? categories[filterCategoryIndex].name : '全部分类'}}</text>
        </view>
      </picker>
      <picker range="{{difficulties}}" value="{{filterDifficultyIndex}}" bindchange="onDifficultyFilterChange">
        <view class="picker-box">
          <text class="field-label">难度</text>
          <text class="picker-value">{{filterDifficultyIndex >= 0 ? difficulties[filterDifficultyIndex] : '全部难度'}}</text>
        </view>
      </picker>
      <input class="field-input" placeholder="搜索菜谱名称或关键词" value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="onSearch" />
    </view>
  </view>

  <view class="recipe-list section-shell" wx:if="{{recipes.length > 0}}">
    <view class="surface-card recipe-card fade-enter" wx:for="{{recipes}}" wx:key="_id">
      <view class="recipe-main" bindtap="previewRecipe" data-id="{{item._id}}">
        <image class="recipe-image" src="{{item.image || '/images/default-dish.png'}}" mode="aspectFill"></image>
        <view class="recipe-copy">
          <view class="chip-row">
            <text class="chip chip-light">{{item.category}}</text>
            <text class="chip chip-mint">{{item.difficulty}}</text>
          </view>
          <text class="recipe-title">{{item.title}}</text>
          <text class="recipe-desc">{{item.description}}</text>
          <view class="recipe-meta">
            <text class="meta-pill">{{item.cookingTime}}</text>
            <text class="meta-pill">{{item.servings}} 人</text>
            <text class="meta-pill">{{item.calories || '--'}} kcal</text>
          </view>
          <view class="tag-box" wx:if="{{item.tags && item.tags.length}}">
            <view class="tag-item" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">
              <text>{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="recipe-actions">
        <view class="ghost-btn mini-btn" bindtap="previewRecipe" data-id="{{item._id}}">预览</view>
        <view class="ghost-btn mini-btn" bindtap="editRecipe" data-id="{{item._id}}">编辑</view>
        <view class="danger-btn mini-btn" bindtap="deleteRecipe" data-id="{{item._id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="surface-card section-shell empty-panel fade-enter" wx:else>
    <text class="empty-title">当前没有匹配到菜谱</text>
    <text class="empty-desc">可以先清空筛选条件，或者直接新增一条内容。</text>
  </view>

  <view class="bottom-dock rise-enter" wx:if="{{recipes.length > 0}}">
    <view class="dock-content">
      <view class="dock-copy">
        <text class="dock-title">第 {{currentPage}} / {{totalPages}} 页</text>
        <text class="dock-desc">如果列表还没到底，可以继续加载更多。</text>
      </view>
      <button class="primary-btn dock-action" bindtap="loadMore" disabled="{{!hasMore || isLoading}}">
        {{isLoading ? '加载中...' : (hasMore ? '加载更多' : '没有更多了')}}
      </button>
    </view>
  </view>
</view>
