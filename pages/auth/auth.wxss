/* pages/auth/auth.wxss */
.container {
  padding: 0;
  background-color: #f8f9fa;
  min-height: 100vh;
}

/* 头部区域 */
.header {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  color: white;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 授权列表 */
.auth-list {
  padding: 20rpx;
}

.auth-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.auth-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.auth-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.auth-content {
  flex: 1;
}

.auth-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.auth-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.auth-status {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.auth-status.authorized {
  background-color: #d4edda;
  color: #155724;
}

.auth-status.unauthorized {
  background-color: #f8d7da;
  color: #721c24;
}

/* 操作按钮 */
.action-buttons {
  padding: 20rpx;
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  outline: none;
}

.btn-primary {
  background-color: #ff6b6b;
  color: white;
}

.btn-secondary {
  background-color: #6c757d;
  color: white;
}

/* 说明文字 */
.tips {
  margin: 20rpx;
  padding: 30rpx;
  background-color: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tips-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.tips-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}
