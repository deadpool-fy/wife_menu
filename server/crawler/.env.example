ALLOWED_ORIGINS=*
OCR_ONLY_MODE=true
OCR_LANGUAGE=chi_sim+eng
OCR_MAX_IMAGES=9
OCR_MAX_IMAGE_BYTES=5242880
OCR_DOWNLOAD_TIMEOUT=15000

